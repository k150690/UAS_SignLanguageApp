<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#1A237E"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pilih Kategori"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Selesaikan materi untuk klaim koin"
            android:textSize="16sp"
            android:textColor="#FFFDD0"
            android:gravity="center"
            android:layout_marginBottom="32dp"/>

        <Button
            android:id="@+id/btnKategoriAbjad"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:text="Huruf Abjad (A-Z)"
            android:textSize="18sp"
            android:textColor="#1A237E"
            android:backgroundTint="#FFFDD0"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnKategoriHari"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:text="Hari dan Waktu"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4FC3F7"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnKategoriKeluarga"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:text="Anggota Keluarga"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#795548"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnKategoriSapaan"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:text="Kata Sapaan &amp; Ganti"
            android:textSize="18sp"
            android:textColor="#5D4037"
            android:backgroundTint="#FFCDD2"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnBackToMenu"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Kembali ke Menu Utama"
            android:textColor="#1A237E"
            android:backgroundTint="#FFFFFF"
            android:layout_marginTop="16dp"/>

    </LinearLayout>
</ScrollView>