<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"> <View
    android:layout_width="match_parent"
    android:layout_height="180dp"
    android:background="@color/blue"
    app:layout_constraintTop_toTopOf="parent" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="32dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgAvatarEdit"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:src="@drawable/person"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/RoundedImage" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ketuk foto untuk mengubah"
                android:textSize="12sp"
                android:textColor="@color/blue"
                android:textAlignment="center"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp"
                android:textStyle="italic" />

            <EditText
                android:id="@+id/edtEditUsername"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="Masukkan Nama Baru"
                android:padding="16dp"
                android:background="@android:drawable/edit_text"
                android:textColor="@color/blue"
                android:inputType="textPersonName"
                android:textSize="16sp"/>

            <Button
                android:id="@+id/btnSimpanProfile"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Simpan"
                android:backgroundTint="@color/blue"
                android:textColor="@color/white"
                app:cornerRadius="20dp"
                android:layout_marginTop="20dp"/>

            <Button
                android:id="@+id/btnBatalProfile"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Kembali"
                android:backgroundTint="@color/cream"
                android:textColor="@color/blue"
                app:cornerRadius="20dp"
                android:layout_marginTop="8dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>