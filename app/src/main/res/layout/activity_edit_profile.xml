<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".EditProfileActivity">

    <View
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="@color/blue"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="10dp"
        app:cardBackgroundColor="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="32dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ubah Identitas"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/blue"
                android:textAlignment="center"
                android:layout_marginBottom="20dp"/>

            <!-- FrameLayout yang menampung Foto Bulat + Ikon Kamera -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="12dp">

                <!-- CardView Bulat untuk memotong Foto Profil Baru -->
                <androidx.cardview.widget.CardView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    app:cardCornerRadius="50dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@android:color/transparent">

                    <ImageView
                        android:id="@+id/imgAvatarEdit"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/header"
                        android:scaleType="centerCrop"
                        android:clickable="true"
                        android:focusable="true"/>
                </androidx.cardview.widget.CardView>

                <!-- Latar belakang lingkaran kecil untuk ikon kamera -->
                <View
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="bottom|end"
                    android:background="@android:drawable/presence_online"
                    android:backgroundTint="@color/blue" />

                <!-- Ikon Kamera Kecil -->
                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="6dp"
                    android:src="@android:drawable/ic_menu_camera"
                    app:tint="@color/white" />
            </FrameLayout>

            <!-- Teks Petunjuk Tambahan di bawah foto -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ketuk foto untuk mengubah"
                android:textSize="12sp"
                android:textColor="@color/blue"
                android:textAlignment="center"
                android:layout_marginBottom="20dp"
                android:textStyle="italic" />

            <EditText
                android:id="@+id/edtEditUsername"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="Masukkan Nama Baru"
                android:padding="16dp"
                android:background="@drawable/petak"
                android:textColor="@color/blue"
                android:inputType="textPersonName"
                android:textSize="16sp"/>

            <Button
                android:id="@+id/btnSimpanProfile"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Simpan"
                android:backgroundTint="@color/blue"
                android:textColor="@color/white"
                app:cornerRadius="20dp"
                android:layout_marginTop="32dp"/>

            <Button
                android:id="@+id/btnBatalProfile"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Kembali"
                android:backgroundTint="@color/cream"
                android:textColor="@color/blue"
                app:cornerRadius="20dp"
                android:layout_marginTop="12dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>